# Default in code is Android Emulator (10.0.2.2 → your PC’s localhost).
# iOS Simulator: EXPO_PUBLIC_API_BASE=http://127.0.0.1:3001
# Physical phone (same Wi‑Fi): use your PC’s LAN IP, or adb reverse + http://127.0.0.1:3001
# EXPO_PUBLIC_API_BASE=http://127.0.0.1:3001
# Optional Google Places (not required — mock stops work offline)
EXPO_PUBLIC_GOOGLE_PLACES_KEY=
